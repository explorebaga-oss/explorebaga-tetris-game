body{
background:#050505;
color:white;
font-family:Arial;
text-align:center;
margin:0;
}

header{
background:linear-gradient(90deg,#00ff88,#00ccff);
padding:20px;
color:black;
}

.game-container{
display:flex;
justify-content:center;
gap:40px;
margin-top:20px;
flex-wrap:wrap;
}

canvas{
background:#000;
border:4px solid #00ff88;
box-shadow:0 0 20px #00ff88;
}

.side{
background:#111;
padding:20px;
border-radius:10px;
}

button{
padding:10px 20px;
margin:5px;
border:none;
background:#00ff88;
cursor:pointer;
}
