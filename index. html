<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>ExploreBaga Tetris</title>
<link rel="stylesheet" href="style.css">
</head>

<body>

<header>
<h1>ExploreBaga Tetris</h1>
</header>

<section class="panel">

<h2>Create Template</h2>

<input type="file" id="upload">

<div id="gallery"></div>

</section>


<section class="panel">

<h2>Vote Templates</h2>

<div id="voteArea"></div>

</section>


<section class="panel">

<h2>Play</h2>

<canvas id="game" width="300" height="600"></canvas>

<br>

<button id="startBtn">Start Game</button>

</section>


<section class="panel">

<h2>Leaderboard</h2>

<ul id="leaderboard"></ul>

</section>

<script src="app.js"></script>

</body>
</html>
